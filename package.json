{
  "name": "roadmap-tool",
  "version": "1.0.0",
  "description": "Interactive project roadmap and delivery plan builder",
  "main": "server.js",
  "scripts": {
    "build":        "node scripts/build.mjs",
    "watch":        "node scripts/build.mjs --watch",
    "typecheck":    "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "start":        "node server.js",
    "dev":          "nodemon server.js",
    "docker:build": "docker build -t roadmap-tool .",
    "docker:run":   "docker run --rm -p 3000:3000 roadmap-tool"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "esbuild": "^0.27.3",
    "nodemon": "^3.0.2",
    "typescript": "^5.9.3"
  }
}
